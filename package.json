{
  "name": "philosynth-service",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w packages/shared && npm run build -w server && npm run build -w client",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:prompts": "tsx scripts/seed-prompts.ts",
    "seed:configs": "tsx scripts/seed-configs.ts",
    "seed:taxonomy": "tsx scripts/seed-taxonomy.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
